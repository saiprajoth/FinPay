{
  "name": "finpay-v1.0",
  "private": true,
"scripts": {
  "build": "turbo run build",
  "dev": "npm run build --workspace=@repo/db && npm run build --workspace=backend && turbo run dev --filter=frontend --filter=backend",
  "lint": "turbo run lint",
  "format": "prettier --write \"**/*.{ts,tsx,md}\"",
  "check-types": "turbo run check-types"
},
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "prettier": "^3.7.4",
    "prisma": "^7.8.0",
    "turbo": "^2.9.15",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0"
  }
}


